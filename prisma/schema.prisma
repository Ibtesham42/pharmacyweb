// Pharmacy Job Portal — Prisma schema (PostgreSQL / Neon)
// Design rationale: docs/DATABASE.md
// Full-text search (tsvector/GIN + pg_trgm) is applied via prisma/sql/fts.sql
// (run by the seed script) — kept out of the schema to avoid Unsupported-type drift.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────── Enums ───────────────────────────
enum Role {
  ADMIN
  EDITOR
}

enum PostType {
  JOB
  NEWS
  ARTICLE
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  GOVERNMENT
  TEMPORARY
}

enum MediaType {
  IMAGE
  PDF
  VIDEO
  DOC
}

enum AdSlot {
  HOMEPAGE_TOP
  SIDEBAR
  IN_CONTENT
  BETWEEN_CONTENT
  FOOTER
  JOB_PAGE
}

enum AdType {
  ADSENSE
  BANNER_IMAGE
  HTML
}

enum ProductType {
  COURSE
  PDF
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
}

enum EventType {
  PAGE_VIEW
  POST_VIEW
  SEARCH
  AD_IMPRESSION
  AD_CLICK
  OUTBOUND_CLICK
}

// ─────────────────── Digital Resources Marketplace ───────────────────
enum ResourceType {
  PHARMACY_NOTES
  STUDY_GUIDE
  SYLLABUS
  PYQ // previous year question papers
  GPAT_MATERIAL
  NIPER_MATERIAL
  DRUG_INSPECTOR_MATERIAL
  RESEARCH_PAPER
  THESIS
  PRESENTATION
  EBOOK
  PDF_COLLECTION
  MOCK_TEST
  QUESTION_BANK
  STUDY_PACKAGE
}

enum ResourceAccess {
  FREE
  PAID
  PREMIUM // members-only; gating designed for a future membership phase
}

enum ResourceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────── Core ───────────────────────────
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(ADMIN)
  avatarUrl    String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  posts     Post[]
  media     Media[]
  auditLogs AuditLog[]
}

model Post {
  id              String     @id @default(cuid())
  type            PostType
  title           String
  slug            String     @unique
  excerpt         String?
  content         String     @db.Text
  status          PostStatus @default(DRAFT)
  isFeatured      Boolean    @default(false)
  viewCount       Int        @default(0)
  publishedAt     DateTime?
  scheduledAt     DateTime?
  authorId        String
  categoryId      String?
  featuredImageId String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  author        User             @relation(fields: [authorId], references: [id])
  category      Category?        @relation(fields: [categoryId], references: [id])
  featuredImage Media?           @relation("PostFeaturedImage", fields: [featuredImageId], references: [id])
  jobDetail     JobDetail?
  seo           SeoMeta?
  references    Reference[]
  tags          PostTag[]
  gallery       PostMedia[]
  events        AnalyticsEvent[]

  @@index([type, status, publishedAt])
  @@index([status, publishedAt])
  @@index([categoryId])
}

model JobDetail {
  id              String    @id @default(cuid())
  postId          String    @unique
  companyName     String
  companyWebsite  String?
  city            String?
  state           String?
  jobType         JobType
  salaryMin       Int?
  salaryMax       Int?
  salaryText      String?
  currency        String    @default("INR")
  applyUrl        String
  experienceLevel String?
  qualifications  String?
  expiryDate      DateTime?

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([state, city])
  @@index([jobType])
  @@index([expiryDate])
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  parentId    String?
  createdAt   DateTime @default(now())

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  posts    Post[]
}

model Tag {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  posts     PostTag[]
  resources ResourceTag[]
}

model PostTag {
  postId String
  tagId  String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

model Reference {
  id     String @id @default(cuid())
  postId String
  label  String
  url    String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model Media {
  id           String    @id @default(cuid())
  type         MediaType
  url          String
  publicId     String    @unique
  fileName     String
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  alt          String?
  uploadedById String?
  createdAt    DateTime  @default(now())

  uploadedBy        User?       @relation(fields: [uploadedById], references: [id])
  postsFeatured     Post[]      @relation("PostFeaturedImage")
  inGalleries       PostMedia[]
  productDownloads  Product[]   @relation("ProductDownloadFile")
  resourceDownloads Resource[]  @relation("ResourceDownloadFile")

  @@index([type])
}

model PostMedia {
  postId   String
  mediaId  String
  position Int    @default(0)

  post  Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([postId, mediaId])
  @@index([mediaId])
}

model SeoMeta {
  id              String   @id @default(cuid())
  postId          String   @unique
  metaTitle       String?
  metaDescription String?
  canonicalUrl    String?
  ogTitle         String?
  ogDescription   String?
  ogImageUrl      String?
  twitterCard     String   @default("summary_large_image")
  jsonLdType      String?
  keywords        String[]
  noindex         Boolean  @default(false)

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Advertisement {
  id           String   @id @default(cuid())
  name         String
  slot         AdSlot
  type         AdType
  adsenseSlotId String?
  imageUrl     String?
  targetUrl    String?
  htmlSnippet  String?
  isActive     Boolean  @default(true)
  startDate    DateTime?
  endDate      DateTime?
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  createdAt    DateTime @default(now())

  events AnalyticsEvent[]

  @@index([slot, isActive])
}

// ─────────────────── Future commerce (schema now, UI later) ───────────────────
model Product {
  id             String        @id @default(cuid())
  type           ProductType
  name           String
  slug           String        @unique
  description    String?
  priceCents     Int           @default(0)
  currency       String        @default("INR")
  coverImageUrl  String?
  demoVideoUrl   String?
  downloadFileId String?
  status         ProductStatus @default(DRAFT)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  downloadFile Media?      @relation("ProductDownloadFile", fields: [downloadFileId], references: [id])
  orderItems   OrderItem[]

  @@index([type, status])
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  customerEmail String
  customerName  String?
  status        OrderStatus @default(PENDING)
  totalCents    Int
  currency      String      @default("INR")
  createdAt     DateTime    @default(now())

  items    OrderItem[]
  payments Payment[]
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  productId  String
  priceCents Int
  quantity   Int    @default(1)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id                String          @id @default(cuid())
  orderId           String
  provider          PaymentProvider
  providerOrderId   String?
  providerPaymentId String?
  amountCents       Int
  currency          String          @default("INR")
  status            String
  rawPayload        Json?
  createdAt         DateTime        @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ─────────────────────────── Cross-cutting ───────────────────────────
model AnalyticsEvent {
  id        String    @id @default(cuid())
  type      EventType
  path      String?
  postId    String?
  adId      String?
  query     String?
  referrer  String?
  sessionId String?
  country   String?
  userAgent String?
  createdAt DateTime  @default(now())

  post Post?          @relation(fields: [postId], references: [id], onDelete: SetNull)
  ad   Advertisement? @relation(fields: [adId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([postId])
  @@index([query])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  handled   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
}

// ─────────────────────────── AI module ───────────────────────────
// AI config (enabled, model, limits, per-mode toggles, maintenance) is stored
// in SiteSetting under key "ai" (JSON) — see services/ai/settings.ts.
// The Groq API key lives only in env (GROQ_API_KEY), never in the DB.
enum AiMode {
  GENERAL
  PHARMACY_EDU
  CAREER
  JOB_SEARCH
  DRUG_INFO
  PLANT_ID
  MEDICAL_DEVICE
  STUDENT
}

enum AiRole {
  USER
  ASSISTANT
  SYSTEM
}

enum AiRequestStatus {
  SUCCESS
  ERROR
  BLOCKED
}

// A chat thread, keyed by an anonymous browser clientId (no public auth).
model AiConversation {
  id        String   @id @default(cuid())
  clientId  String
  title     String?
  mode      AiMode   @default(GENERAL)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages AiMessage[]

  @@index([clientId, updatedAt])
}

model AiMessage {
  id               String   @id @default(cuid())
  conversationId   String
  role             AiRole
  content          String   @db.Text
  model            String?
  promptTokens     Int?
  completionTokens Int?
  createdAt        DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// One row per AI request — powers admin usage analytics + error logs.
model AiRequestLog {
  id               String          @id @default(cuid())
  clientId         String?
  conversationId   String?
  feature          String          @default("CHAT")
  mode             AiMode          @default(GENERAL)
  model            String
  status           AiRequestStatus @default(SUCCESS)
  promptTokens     Int             @default(0)
  completionTokens Int             @default(0)
  latencyMs        Int?
  errorMessage     String?
  ip               String?
  createdAt        DateTime        @default(now())

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([clientId, createdAt])
}

// Admin-uploaded source material for future RAG. Embeddings (pgvector) are
// designed but deferred — see docs/AI.md. mediaId is a soft reference to Media.
model AiKnowledgeFile {
  id          String   @id @default(cuid())
  title       String
  description String?
  sourceUrl   String?
  mediaId     String?
  fileType    String   @default("PDF")
  status      String   @default("PENDING")
  tokenCount  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

// ─────────────────────────── Donations ───────────────────────────
// Donation config (enabled, UPI id, QR url, goals, amounts, messages) lives in
// SiteSetting key "donations" (JSON). Razorpay keys live only in env, never in DB.
enum DonationStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DonationMethod {
  RAZORPAY
  UPI_MANUAL
}

// Featured-supporter moderation lifecycle. A donation only appears in the public
// supporters wall once an admin moves it to APPROVED — consent alone is not enough.
enum FeatureStatus {
  NONE     // donor did not opt in
  PENDING  // donor opted in; awaiting admin review
  APPROVED // admin approved → eligible for public display (if PAID)
  REJECTED // admin declined / removed from the featured list
}

model Donation {
  id                String         @id @default(cuid())
  receiptNo         String         @unique
  name              String
  email             String
  phone             String?
  city              String?
  state             String?
  address           String?
  amountPaise       Int
  currency          String         @default("INR")
  method            DonationMethod
  status            DonationStatus @default(PENDING)
  anonymous         Boolean        @default(false)
  supporterConsent  Boolean        @default(false)
  featureStatus     FeatureStatus  @default(NONE)
  featuredMessage   String?        @db.Text // admin-curated public thank-you note
  featuredAt        DateTime? // when an admin approved/featured this supporter
  reason            String?
  feedback          String?        @db.Text
  source            String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  transactionRef    String?
  ip                String?
  createdAt         DateTime       @default(now())
  paidAt            DateTime?

  @@index([status, createdAt])
  @@index([email])
  @@index([createdAt])
  @@index([featureStatus, featuredAt])
}

// ─────────────────── Digital Resources Marketplace ───────────────────
// Downloadable resources (free/paid). Paid files are stored as Cloudinary
// "authenticated" assets and only served via an entitlement-checked, expiring
// signed URL — see lib/cloudinary.ts + app/api/resources/[slug]/download.
// Marketplace config lives in SiteSetting key "marketplace" (JSON).

model ResourceCategory {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  parentId    String?
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())

  parent    ResourceCategory?  @relation("ResourceCategoryTree", fields: [parentId], references: [id])
  children  ResourceCategory[] @relation("ResourceCategoryTree")
  resources Resource[]
}

model Resource {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  type        ResourceType
  categoryId  String?
  description String         @db.Text
  excerpt     String?
  author      String?
  access      ResourceAccess @default(FREE)
  pricePaise  Int            @default(0)
  status      ResourceStatus @default(DRAFT)

  // Protected download file (Cloudinary authenticated asset) + metadata
  fileId        String?
  fileType      String? // e.g. "PDF", "ZIP"
  fileSizeBytes Int?
  pageCount     Int?
  previewImages String[] // public Cloudinary URLs

  // Engagement + rating aggregates (denormalized)
  downloadCount Int @default(0)
  viewCount     Int @default(0)
  ratingSum     Int @default(0)
  ratingCount   Int @default(0)

  // Inline SEO (avoids coupling to SeoMeta which is Post-only)
  metaTitle       String?
  metaDescription String?
  ogImageUrl      String?

  // Thesis / research (nullable; DOI-ready for a future library phase)
  abstract      String? @db.Text
  citation      String? @db.Text
  doi           String?
  publishedYear Int?

  featured    Boolean   @default(false)
  publishedAt DateTime?
  deletedAt   DateTime? // soft delete
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category  ResourceCategory?  @relation(fields: [categoryId], references: [id])
  file      Media?             @relation("ResourceDownloadFile", fields: [fileId], references: [id])
  tags      ResourceTag[]
  purchases ResourcePurchase[]
  reviews   ResourceReview[]
  bookmarks ResourceBookmark[]
  downloads ResourceDownload[]

  @@index([type, status])
  @@index([access, status])
  @@index([categoryId])
  @@index([status, publishedAt])
  @@index([featured])
}

model ResourceTag {
  resourceId String
  tagId      String

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([resourceId, tagId])
  @@index([tagId])
}

// Passwordless public buyer account (separate from admin User).
model Buyer {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified Boolean   @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())

  purchases ResourcePurchase[]
  reviews   ResourceReview[]
  bookmarks ResourceBookmark[]
  downloads ResourceDownload[]
}

// Magic-link / OTP tokens. Only the hash is stored.
model BuyerAuthToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  code      String? // optional 6-digit OTP (also hashed)
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

// Single-resource purchase (mirrors Donation; reuses lib/razorpay.ts).
model ResourcePurchase {
  id                String         @id @default(cuid())
  receiptNo         String         @unique
  buyerId           String?
  resourceId        String
  email             String
  name              String?
  amountPaise       Int
  currency          String         @default("INR")
  method            DonationMethod
  status            OrderStatus    @default(PENDING)
  razorpayOrderId   String?
  razorpayPaymentId String?
  transactionRef    String?
  ip                String?
  createdAt         DateTime       @default(now())
  paidAt            DateTime?

  buyer    Buyer?   @relation(fields: [buyerId], references: [id])
  resource Resource @relation(fields: [resourceId], references: [id])

  @@index([buyerId])
  @@index([resourceId])
  @@index([status])
  @@index([email])
  @@index([razorpayOrderId])
}

model ResourceReview {
  id         String       @id @default(cuid())
  resourceId String
  buyerId    String
  rating     Int // 1..5
  title      String?
  body       String?      @db.Text
  status     ReviewStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  buyer    Buyer    @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@unique([resourceId, buyerId])
  @@index([resourceId, status])
}

model ResourceBookmark {
  id         String   @id @default(cuid())
  buyerId    String
  resourceId String
  createdAt  DateTime @default(now())

  buyer    Buyer    @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([buyerId, resourceId])
  @@index([resourceId])
}

model ResourceDownload {
  id         String   @id @default(cuid())
  resourceId String
  buyerId    String?
  email      String?
  ip         String?
  createdAt  DateTime @default(now())

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  buyer    Buyer?   @relation(fields: [buyerId], references: [id])

  @@index([resourceId, createdAt])
  @@index([buyerId])
}
