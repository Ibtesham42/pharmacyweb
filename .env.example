# ─────────────────────────────────────────────────────────────
# Pharmacy Portal — environment variables
# Copy to `.env` (local) and set the same in Vercel project settings.
# ─────────────────────────────────────────────────────────────

# Database (Neon Postgres)
# DATABASE_URL  -> pooled connection used by the app at runtime
# DIRECT_URL    -> direct connection used by Prisma Migrate
DATABASE_URL="postgresql://user:password@host/db?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# Auth.js (NextAuth v5)
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Seed admin (used by prisma/seed.ts to create the first admin)
ADMIN_EMAIL="admin@pharmacyportal.in"
ADMIN_PASSWORD="ChangeThisStrongPassword123!"
ADMIN_NAME="Site Admin"

# Cloudinary (media: images / PDFs)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# Google AdSense (public client id, e.g. ca-pub-XXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_CLIENT=""
NEXT_PUBLIC_ADSENSE_ENABLED="false"

# AI assistant (Groq). Server-only secret — NEVER exposed to the client.
# Get a key at https://console.groq.com/keys . Enable + configure in Admin → AI Settings.
GROQ_API_KEY=""

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="PharmaCareers"

# Rate limiting (optional Upstash Redis for production; in-memory fallback used if unset)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Donations / Payments — Razorpay (optional; UPI/QR works without these).
# Set the webhook secret + register the webhook URL /api/razorpay/webhook in Razorpay.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
